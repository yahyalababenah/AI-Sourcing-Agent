# ===================================================================
# AI-Sourcing Hub — HuggingFace Spaces Dockerfile
# Port: 7860 (HF Spaces default)
# External services: Supabase (PostgreSQL) + Upstash (Redis)
# ===================================================================

FROM python:3.12-slim-bookworm AS base

ENV \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_DEFAULT_TIMEOUT=120 \
    VIRTUAL_ENV=/opt/venv

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libgdk-pixbuf2.0-0 \
    libffi-dev \
    libcairo2 \
    poppler-utils \
    libpq-dev \
    libgl1-mesa-glx \
    libglib2.0-0 \
    curl \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# TEMPORARY: single-session demo only. Bundles MinIO inside the app image so
# a live catalog upload works on HF Spaces without an external S3 account.
# Storage is ephemeral (/data/minio) and is wiped on every Space restart/rebuild.
# See docs/hf-spaces-env.md for the real (external S3) setup recommended for
# any use beyond a one-off demo.
RUN curl -fsSL https://dl.min.io/server/minio/release/linux-amd64/minio \
    -o /usr/local/bin/minio && chmod +x /usr/local/bin/minio

# ---- Builder ----
FROM base AS builder

RUN python -m venv $VIRTUAL_ENV
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# ---- Production ----
FROM base AS production

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN groupadd -r aisourcing && useradd -r -g aisourcing -d /app -s /bin/false aisourcing

WORKDIR /app

COPY --chown=aisourcing:aisourcing . .

RUN mkdir -p /app/app/static/fonts /app/app/static/logos \
             /app/.paddleocr /app/.paddlex /data/minio && \
    chown -R aisourcing:aisourcing /app /data/minio && \
    chmod +x /app/entrypoint.hf.sh

ENV PADDLEOCR_HOME=/app/.paddleocr

# TEMPORARY: single-session demo defaults for the in-container MinIO above.
# /data/minio is ephemeral — wiped on every Space restart/rebuild.
ENV MINIO_ROOT_USER=minioadmin \
    MINIO_ROOT_PASSWORD=minioadmin \
    S3_ENDPOINT=http://localhost:9000 \
    S3_ACCESS_KEY=minioadmin \
    S3_SECRET_KEY=minioadmin

# Single-container performance mode. There is no Celery worker here (process
# documents inline), Redis/DB are remote so rate-limit in-memory to cut per-
# request round trips, and skip the per-request session-invalidation Redis GET.
ENV CELERY_ENABLED=false \
    RATE_LIMIT_BACKEND=memory \
    AUTH_SESSION_CHECK_ENABLED=false

USER aisourcing

EXPOSE 7860

ENTRYPOINT ["/app/entrypoint.hf.sh"]
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "7860"]
