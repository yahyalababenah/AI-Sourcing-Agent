# ===================================================================
# AI-Sourcing Hub — Environment Variables
# Copy this file to .env and fill in all required values
# ===================================================================

# ---- Database ----
DB_PASSWORD=change_me_secure_random_password_20_chars

# ---- Redis ----
REDIS_PASSWORD=change_me_secure_random_password_20_chars

# ---- JWT Authentication ----
JWT_SECRET=change_me_64_char_plus_random_secret_key_here_please_replace
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- LLM API Providers ----
# Together AI (primary)
TOGETHER_API_KEY=together_ai_api_key_here

# OpenRouter (fallback)
OPENROUTER_API_KEY=openrouter_api_key_here

# ---- Exchange Rate API ----
EXCHANGE_RATE_API_KEY=exchange_rate_api_key_here

# ---- Object Storage (MinIO) ----
MINIO_ACCESS_KEY=minio_access_key_here
MINIO_SECRET_KEY=minio_secret_key_here
MINIO_BUCKET_DOCUMENTS=aisourcing-documents
MINIO_BUCKET_QUOTES=aisourcing-quotes

# ---- Sentry Error Tracking ----
SENTRY_DSN=

# ---- Security ----
ALLOWED_HOSTS=localhost,127.0.0.1,api,*.aisourcing.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---- Environment ----
ENVIRONMENT=development

# ---- Celery ----
# These are auto-constructed from REDIS_URL in config.py
# CELERY_BROKER_URL=redis://:password@redis:6379/1
# CELERY_RESULT_BACKEND=redis://:password@redis:6379/2
